{
  "pluginAlias": "BroadlinkRM4ProBlaster",
  "pluginType": "platform",
  "singular": true,
  "headerDisplay": "Blasts pre-recorded IR/RF hex signals via a Broadlink RM4 Pro. Signals must be captured elsewhere (this plugin does not learn or discover devices).",
  "schema": {
    "type": "object",
    "properties": {
      "defaultIp": {
        "title": "Default RM4 Pro IP Address",
        "type": "string",
        "format": "ipv4",
        "required": true,
        "description": "Used by any accessory below that doesn't specify its own IP address."
      },
      "accessories": {
        "title": "Accessories",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "required": true
            },
            "ip": {
              "title": "IP Address",
              "type": "string",
              "format": "ipv4",
              "required": false,
              "description": "Overrides the default IP address above. Leave empty to use the default."
            },
            "accessoryType": {
              "title": "Accessory Type",
              "type": "string",
              "required": true,
              "default": "light",
              "oneOf": [
                { "title": "Light", "enum": ["light"] },
                { "title": "Switch", "enum": ["switch"] },
                { "title": "Outlet", "enum": ["outlet"] },
                { "title": "Fan", "enum": ["fan"] }
              ]
            },
            "powerOnCode": {
              "title": "Power On Signal",
              "type": "string",
              "required": true,
              "description": "Hex code sent to turn the accessory on."
            },
            "powerOffCode": {
              "title": "Power Off Signal",
              "type": "string",
              "required": false,
              "description": "Hex code sent to turn the accessory off. Leave empty to reuse the Power On signal (useful for toggle-only remotes)."
            }
          }
        }
      },
      "dimmers": {
        "title": "Dimmer Lights",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "required": true
            },
            "ip": {
              "title": "IP Address",
              "type": "string",
              "format": "ipv4",
              "required": false,
              "description": "Overrides the default IP address above. Leave empty to use the default."
            },
            "powerOnCode": {
              "title": "Power On Signal",
              "type": "string",
              "required": false,
              "description": "Hex code sent to turn the light on. Leave empty to just send the resolved brightness level's signal instead."
            },
            "powerOffCode": {
              "title": "Power Off Signal",
              "type": "string",
              "required": false,
              "description": "Hex code sent to turn the light off. Leave empty to reuse the Brightness 0% signal."
            },
            "useLastKnownBrightness": {
              "title": "Use Last Known Brightness",
              "type": "boolean",
              "required": false,
              "description": "When turning on, restore the last brightness this light was set to instead of a default/max/highest level."
            },
            "zeroPercentCode": {
              "title": "Brightness 0% Signal",
              "type": "string",
              "required": true,
              "description": "Hex code for the lowest (0%) brightness level."
            },
            "levels": {
              "title": "Brightness Levels",
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "properties": {
                  "level": {
                    "title": "Brightness Level (%)",
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 100,
                    "required": true
                  },
                  "code": {
                    "title": "Signal",
                    "type": "string",
                    "required": true
                  },
                  "isDefault": {
                    "title": "Default Brightness",
                    "type": "boolean",
                    "required": false,
                    "description": "Used when turning on if no last-known brightness applies. Only one level should be marked default."
                  },
                  "isMax": {
                    "title": "Max Brightness",
                    "type": "boolean",
                    "required": false,
                    "description": "Caps and remaps the 0-100% slider onto this level. Only one level should be marked max."
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "layout": [
    {
      "type": "fieldset",
      "title": "General",
      "items": ["defaultIp"]
    },
    {
      "type": "array",
      "key": "accessories",
      "title": "Accessories",
      "items": [
        "accessories[].name",
        "accessories[].ip",
        "accessories[].accessoryType",
        "accessories[].powerOnCode",
        "accessories[].powerOffCode"
      ]
    },
    {
      "type": "array",
      "key": "dimmers",
      "title": "Dimmer Lights",
      "items": [
        "dimmers[].name",
        "dimmers[].ip",
        "dimmers[].powerOnCode",
        "dimmers[].powerOffCode",
        "dimmers[].useLastKnownBrightness",
        "dimmers[].zeroPercentCode",
        {
          "type": "array",
          "key": "dimmers[].levels",
          "title": "Brightness Levels",
          "items": [
            "dimmers[].levels[].level",
            "dimmers[].levels[].code",
            "dimmers[].levels[].isDefault",
            "dimmers[].levels[].isMax"
          ]
        }
      ]
    }
  ]
}
